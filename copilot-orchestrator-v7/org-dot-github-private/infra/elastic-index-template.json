{
  "index_patterns": ["copilot-audit-*"],
  "priority": 200,
  "template": {
    "settings": {
      "number_of_shards": 1,
      "number_of_replicas": 1,
      "refresh_interval": "5s",
      "index.lifecycle.name": "copilot-audit-ilm",
      "index.lifecycle.rollover_alias": "copilot-audit"
    },
    "mappings": {
      "dynamic": "strict",
      "properties": {
        "@timestamp":   { "type": "date" },
        "session_id":   { "type": "keyword" },
        "step_id":      { "type": "keyword" },
        "agent":        { "type": "keyword" },
        "model":        { "type": "keyword" },
        "phase":        { "type": "keyword" },
        "tool":         { "type": "keyword" },
        "tool_status":  { "type": "keyword" },
        "files":        { "type": "keyword" },
        "args_hash":    { "type": "keyword" },
        "req_ids":      { "type": "keyword" },
        "jira_keys":    { "type": "keyword" },
        "scenario_tags":{ "type": "keyword" },
        "commit_sha":   { "type": "keyword" },
        "pr_number":    { "type": "integer" },
        "branch":       { "type": "keyword" },
        "actor":        { "type": "keyword" },
        "repo":         { "type": "keyword" },
        "tokens_in":    { "type": "long" },
        "tokens_out":   { "type": "long" },
        "latency_ms":   { "type": "long" },
        "cost_usd":     { "type": "scaled_float", "scaling_factor": 1000000 },
        "error":        { "type": "text" },
        "user_message_redacted": { "type": "boolean" }
      }
    }
  },
  "_meta": {
    "description": "Audit events emitted by the Copilot orchestrator agents",
    "owner": "platform-team"
  }
}
